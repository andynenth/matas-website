---
export interface Props {
  lang?: 'th' | 'en';
  currentPath?: string;
}

const { lang = 'th', currentPath = '/' } = Astro.props;

const navigation = lang === 'th'
  ? [
      { name: 'หน้าแรก', href: '/' },
      { name: 'เกี่ยวกับเรา', href: '/about' },
      { name: 'บริการ', href: '/services' },
      { name: 'คำถามที่พบบ่อย', href: '/faq' },
      { name: 'ติดต่อเรา', href: '/contact' }
    ]
  : [
      { name: 'Home', href: '/en/' },
      { name: 'About Us', href: '/en/about' },
      { name: 'Services', href: '/en/services' },
      { name: 'FAQ', href: '/en/faq' },
      { name: 'Contact', href: '/en/contact' }
    ];

const siteName = lang === 'th' ? 'สำนักกฎหมายมิตรแสนสุข' : 'MS Law Office';
const siteTagline = lang === 'th'
  ? 'บริการใกล้ตัว มาตรฐานระดับสากล'
  : 'Local Care, International Confidence';

const isActive = (path: string) => {
  if (lang === 'en') {
    return currentPath === path || currentPath === path.replace('/en', '');
  }
  return currentPath === path;
};
---

<style>
/* Updated hover styles - cache bust 2026-03-04-v4 */
nav.header.bg-master-darker a {
  transition: all 0.3s ease !important;
}

/* Menu navigation links */
nav.header.bg-master-darker .menu li a {
  color: #ffffff !important;
  transition: all 0.3s ease !important;
}

nav.header.bg-master-darker .menu li a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
}

/* Contact and language toggle links */
nav.header.bg-master-darker a:hover,
nav.header.bg-master-darker .language-toggle a:hover,
nav.header.bg-master-darker .header-inner a:hover,
nav.header.bg-master-darker div a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
  transform: none !important;
}

/* Mobile Responsive Styles (max-width: 767px) */
@media (max-width: 767px) {
  /* Mobile optimizations */
  .logo h3 {
    font-size: 16px !important;
  }

  /* Mobile navigation text sizing */
  nav.header.bg-master-darker .menu li a {
    font-size: 20px !important;
  }
}

/* Tablet Responsive Styles (768px - 991px) */
@media (min-width: 768px) and (max-width: 991px) {
  /* Ensure proper spacing on tablet */
  .header-inner {
    justify-content: space-between !important;
  }

  /* Optimize logo area for tablets */
  .logo h3 {
    font-size: 18px !important;
  }

  /* Prevent overflow on tablet */
  .pull-right .header-inner {
    flex-wrap: nowrap !important;
    overflow: hidden !important;
  }
}

/* Desktop Responsive Styles (min-width: 992px) */
@media (min-width: 992px) {
  /* Hide hamburger button on desktop - force hide with multiple selectors */
  nav.header.bg-master-darker .menu-toggler,
  .menu-toggler.visible-sm-inline,
  .menu-toggler.visible-xs-inline {
    display: none !important;
    visibility: hidden !important;
  }

  /* Desktop text optimizations */
  .visible-md-inline {
    white-space: nowrap !important;
  }
}

/* Mobile hamburger menu button styling */
nav.header.bg-master-darker .menu-toggler {
  border: 1px solid #ffffff !important;
  border-radius: 8px !important;
  background-color: transparent !important;
  padding: 8px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex-direction: column !important;
  margin-top: 2px !important;
}

nav.header.bg-master-darker .menu-toggler .one,
nav.header.bg-master-darker .menu-toggler .two,
nav.header.bg-master-darker .menu-toggler .three {
  background-color: #ffffff !important;
}


/* CSS Custom Properties */
:root {
  --header-height: 60px;
  --header-gap-large: 15px;
  --header-gap-medium: 10px;
  --header-gap-small: 5px;
  --icon-spacing: 5px;
  --logo-size: 18px;
  --separator-margin: 5px;
  --mobile-sticky-z: 1000;
  --mobile-padding: 10px;
}

/* Semantic CSS Classes for Header Layout */
.header-inner-flex {
  display: flex;
  align-items: center;
  height: var(--header-height);
}

.logo-title {
  margin: 0;
  line-height: 1.2;
}

.contact-container-large {
  display: inline-flex;
  align-items: center;
  gap: var(--header-gap-large);
}

.contact-container-medium {
  display: inline-flex;
  align-items: center;
  gap: var(--header-gap-medium);
}

.contact-link {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
}

.contact-link-padded {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
  padding: 2px 4px;
}

.icon-with-spacing {
  margin-right: var(--icon-spacing);
  vertical-align: middle;
}

.logo-sizing {
  width: var(--logo-size);
  height: var(--logo-size);
  vertical-align: middle;
}

.logo-sizing-mobile {
  width: 20px;
  height: 20px;
}

.separator-spacing {
  margin: 0 var(--separator-margin);
}

.separator-spacing-small {
  margin: 0 4px;
}

.mobile-sticky-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--mobile-sticky-z);
  padding: var(--mobile-padding);
}

.button-flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hidden-element {
  display: none;
}

</style>

<!-- BEGIN HEADER -->
<nav class="header bg-master-darker" data-pages="header">
  <div class="container relative">
    <!-- BEGIN LEFT CONTENT -->
    <div class="pull-left">
      <!-- .header-inner Allows to vertically Align elements to the Center-->
      <div class="header-inner header-inner-flex">
        <!-- BEGIN LOGO -->
        <div class="logo">
          <a href={lang === 'en' ? '/en/' : '/'}>
            <h3 class="text-white bold logo-title">{siteName}</h3>
          </a>
        </div>
      </div>
    </div>

    <!-- BEGIN HEADER TOGGLE FOR MOBILE & TABLET -->
    <div class="pull-right">
      <div class="header-inner header-inner-flex">
        <!-- Contact Info for Large Desktop (1200px+) -->
        <div class="visible-lg-inline hidden-xs hidden-sm p-r-20 contact-container-large">
          <a href="tel:+66815144783" onclick="trackPhoneClick()" class="text-white fs-12 contact-link">
            <i class="fa fa-phone icon-with-spacing"></i> 081-514-4783
          </a>

          <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="text-success fs-12 contact-link-padded">
            <img src="/assets/images/line-logo.png" alt="LINE" class="logo-sizing" />
          </a>

          <!-- Language Toggle -->
          <div class="language-toggle fs-12 contact-link">
            {lang === 'th' ? (
              <div class="contact-link">
                <span class="text-white font-montserrat bold">🇹🇭 TH</span>
                <span class="text-white-50 separator-spacing">|</span>
                <a href={currentPath === '/' ? '/en/' : `/en${currentPath}`} class="text-white">
                  🇺🇸 EN
                </a>
              </div>
            ) : (
              <div class="contact-link">
                <a href={currentPath === '/en/' ? '/' : currentPath.replace('/en', '')} class="text-white">
                  🇹🇭 TH
                </a>
                <span class="text-white-50 separator-spacing">|</span>
                <span class="text-white font-montserrat bold">🇺🇸 EN</span>
              </div>
            )}
          </div>
        </div>

        <!-- Tablet-Optimized Contact (768-1199px) -->
        <div class="visible-md-inline hidden-lg hidden-xs hidden-sm p-r-15 contact-container-medium">
          <a href="tel:+66815144783" onclick="trackPhoneClick()" class="text-white fs-11 contact-link">
            <i class="fa fa-phone icon-with-spacing"></i> 081-514-4783
          </a>

          <!-- Tablet Language Toggle -->
          <div class="language-toggle fs-11 contact-link">
            {lang === 'th' ? (
              <div class="contact-link">
                <span class="text-white font-montserrat bold">🇹🇭</span>
                <span class="text-white-50 separator-spacing-small">|</span>
                <a href={currentPath === '/' ? '/en/' : `/en${currentPath}`} class="text-white">🇺🇸</a>
              </div>
            ) : (
              <div class="contact-link">
                <a href={currentPath === '/en/' ? '/' : currentPath.replace('/en', '')} class="text-white">🇹🇭</a>
                <span class="text-white-50 separator-spacing-small">|</span>
                <span class="text-white font-montserrat bold">🇺🇸</span>
              </div>
            )}
          </div>
        </div>

        <div class="visible-sm-inline visible-xs-inline hidden-lg hidden-md menu-toggler pull-right p-l-10" data-pages="header-toggle" data-pages-element="#header">
          <div class="one"></div>
          <div class="two"></div>
          <div class="three"></div>
        </div>
      </div>
    </div>
    <!-- END HEADER TOGGLE FOR MOBILE & TABLET -->

    <!-- BEGIN RIGHT CONTENT -->
    <div class="menu-content mobile-dark pull-right clearfix" data-pages-direction="slideRight" id="header">
      <!-- BEGIN HEADER CLOSE TOGGLE FOR MOBILE -->
      <div class="pull-right">
        <a href="#" class="padding-10 visible-xs-inline visible-sm-inline pull-right m-t-10 m-b-10 m-r-10" data-pages="header-toggle" data-pages-element="#header">
          <i class="pg-close_line"></i>
        </a>
      </div>
      <!-- END HEADER CLOSE TOGGLE FOR MOBILE -->

      <!-- BEGIN MENU ITEMS -->
      <div class="header-inner">
        <ul class="menu">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.name}</a>
            </li>
          ))}

        </ul>

        <!-- Mobile Contact Info -->
        <div class="visible-xs-block visible-sm-block m-t-20">
          <div class="b-b b-grey-light p-b-10 m-b-10">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-block btn-success m-b-5 hidden-element">
              <i class="fa fa-phone"></i> {lang === 'th' ? 'โทรศัพท์' : 'Call'} 081-514-4783
            </a>
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-block btn-complete m-b-10 hidden-element">
              <img src="/assets/images/line-logo.png" alt="LINE" style="width: 24px; height: 24px;" />
            </a>

            <!-- Mobile Language Toggle -->
            <div class="text-center p-t-10">
              <div class="language-toggle-mobile">
                {lang === 'th' ? (
                  <div>
                    <span class="text-white bold fs-14">🇹🇭 ไทย</span>
                    <span class="hint-text p-l-10 p-r-10">|</span>
                    <a href={currentPath === '/' ? '/en/' : `/en${currentPath}`} class="text-white-50 fs-14">
                      🇺🇸 English
                    </a>
                  </div>
                ) : (
                  <div>
                    <a href={currentPath === '/en/' ? '/' : currentPath.replace('/en', '')} class="text-white-50 fs-14">
                      🇹🇭 ไทย
                    </a>
                    <span class="hint-text p-l-10 p-r-10">|</span>
                    <span class="text-white bold fs-14">🇺🇸 English</span>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
<!-- END HEADER -->

<!-- Mobile Sticky Contact Bar -->
<div class="visible-xs-block visible-sm-block mobile-sticky-bar">
  <div class="row no-padding">
    <div class="col-xs-6 no-padding p-r-5">
      <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-success btn-block">
        <i class="fa fa-phone"></i> {lang === 'th' ? 'โทร' : 'Call'}
      </a>
    </div>
    <div class="col-xs-6 no-padding p-l-5">
      <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-complete btn-block button-flex-center">
        <img src="/assets/images/line-logo.png" alt="LINE" class="logo-sizing-mobile" />
      </a>
    </div>
  </div>
</div>