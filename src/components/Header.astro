---
export interface Props {
  lang?: 'th' | 'en';
  currentPath?: string;
}

const { lang = 'th', currentPath = '/' } = Astro.props;

const navigation = lang === 'th'
  ? [
      { name: 'หน้าแรก', href: '/' },
      { name: 'เกี่ยวกับเรา', href: '/about' },
      { name: 'บริการ', href: '/services' },
      { name: 'คำถามที่พบบ่อย', href: '/faq' },
      { name: 'ติดต่อเรา', href: '/contact' }
    ]
  : [
      { name: 'Home', href: '/en/' },
      { name: 'About Us', href: '/en/about' },
      { name: 'Services', href: '/en/services' },
      { name: 'FAQ', href: '/en/faq' },
      { name: 'Contact', href: '/en/contact' }
    ];

const siteName = lang === 'th' ? 'สำนักกฎหมายมิตรแสนสุข' : 'MS Law Office';
const siteTagline = lang === 'th'
  ? 'บริการใกล้ตัว มาตรฐานระดับสากล'
  : 'Local Care, International Confidence';

const isActive = (path: string) => {
  if (lang === 'en') {
    return currentPath === path || currentPath === path.replace('/en', '');
  }
  return currentPath === path;
};
---

<style>
/* Updated hover styles - cache bust 2026-03-04-v3 */
nav.header.bg-master-darker a {
  transition: all 0.3s ease !important;
}

/* Menu navigation links */
nav.header.bg-master-darker .menu li a {
  color: #ffffff !important;
  transition: all 0.3s ease !important;
}

nav.header.bg-master-darker .menu li a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
}

/* Contact and language toggle links */
nav.header.bg-master-darker a:hover,
nav.header.bg-master-darker .language-toggle a:hover,
nav.header.bg-master-darker .header-inner a:hover,
nav.header.bg-master-darker div a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
  transform: none !important;
}
</style>

<!-- BEGIN HEADER -->
<nav class="header bg-master-darker" data-pages="header">
  <div class="container relative">
    <!-- BEGIN LEFT CONTENT -->
    <div class="pull-left">
      <!-- .header-inner Allows to vertically Align elements to the Center-->
      <div class="header-inner" style="display: flex; align-items: center; height: 60px;">
        <!-- BEGIN LOGO -->
        <div class="logo">
          <a href={lang === 'en' ? '/en/' : '/'}>
            <h3 class="text-white font-montserrat" style="margin: 0; line-height: 1.2;">{siteName}</h3>
          </a>
        </div>
      </div>
    </div>

    <!-- BEGIN HEADER TOGGLE FOR MOBILE & TABLET -->
    <div class="pull-right">
      <div class="header-inner" style="display: flex; align-items: center; height: 60px;">
        <!-- Contact Info for Desktop -->
        <div class="visible-lg-inline visible-md-inline p-r-20" style="display: inline-flex; align-items: center; gap: 15px;">
          <a href="tel:+66815144783" onclick="trackPhoneClick()" class="text-white fs-12" style="display: inline-flex; align-items: center; vertical-align: middle;">
            <i class="fa fa-phone" style="margin-right: 5px; vertical-align: middle;"></i> 081-514-4783
          </a>

          <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="text-success fs-12" style="display: inline-flex; align-items: center; vertical-align: middle; padding: 2px 4px;">
            <img src="/assets/images/line-logo.png" alt="LINE" style="width: 18px; height: 18px; vertical-align: middle;" />
          </a>

          <!-- Language Toggle -->
          <div class="language-toggle fs-12" style="display: inline-flex; align-items: center;">
            {lang === 'th' ? (
              <div style="display: inline-flex; align-items: center;">
                <span class="text-white font-montserrat bold">🇹🇭 TH</span>
                <span class="text-white-50" style="margin: 0 5px;">|</span>
                <a href={currentPath === '/' ? '/en/' : `/en${currentPath}`} class="text-white">
                  🇺🇸 EN
                </a>
              </div>
            ) : (
              <div style="display: inline-flex; align-items: center;">
                <a href={currentPath === '/en/' ? '/' : currentPath.replace('/en', '')} class="text-white">
                  🇹🇭 TH
                </a>
                <span class="text-white-50" style="margin: 0 5px;">|</span>
                <span class="text-white font-montserrat bold">🇺🇸 EN</span>
              </div>
            )}
          </div>
        </div>

        <div class="visible-sm-inline visible-xs-inline menu-toggler pull-right p-l-10" data-pages="header-toggle" data-pages-element="#header">
          <div class="one"></div>
          <div class="two"></div>
          <div class="three"></div>
        </div>
      </div>
    </div>
    <!-- END HEADER TOGGLE FOR MOBILE & TABLET -->

    <!-- BEGIN RIGHT CONTENT -->
    <div class="menu-content mobile-dark pull-right clearfix" data-pages-direction="slideRight" id="header">
      <!-- BEGIN HEADER CLOSE TOGGLE FOR MOBILE -->
      <div class="pull-right">
        <a href="#" class="padding-10 visible-xs-inline visible-sm-inline pull-right m-t-10 m-b-10 m-r-10" data-pages="header-toggle" data-pages-element="#header">
          <i class="pg-close_line"></i>
        </a>
      </div>
      <!-- END HEADER CLOSE TOGGLE FOR MOBILE -->

      <!-- BEGIN MENU ITEMS -->
      <div class="header-inner">
        <ul class="menu">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.name}</a>
            </li>
          ))}

        </ul>

        <!-- Mobile Contact Info -->
        <div class="visible-xs-block visible-sm-block m-t-20">
          <div class="b-b b-grey-light p-b-10 m-b-10">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-block btn-success m-b-5">
              <i class="fa fa-phone"></i> {lang === 'th' ? 'โทรศัพท์' : 'Call'} 081-514-4783
            </a>
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-block btn-complete m-b-10" style="display: flex; align-items: center; justify-content: center;">
              <img src="/assets/images/line-logo.png" alt="LINE" style="width: 24px; height: 24px;" />
            </a>

            <!-- Mobile Language Toggle -->
            <div class="text-center p-t-10">
              <div class="language-toggle-mobile">
                {lang === 'th' ? (
                  <div>
                    <span class="text-white font-montserrat bold fs-14">🇹🇭 ไทย</span>
                    <span class="hint-text p-l-10 p-r-10">|</span>
                    <a href={currentPath === '/' ? '/en/' : `/en${currentPath}`} class="text-black fs-14">
                      🇺🇸 English
                    </a>
                  </div>
                ) : (
                  <div>
                    <a href={currentPath === '/en/' ? '/' : currentPath.replace('/en', '')} class="text-black fs-14">
                      🇹🇭 ไทย
                    </a>
                    <span class="hint-text p-l-10 p-r-10">|</span>
                    <span class="text-white font-montserrat bold fs-14">🇺🇸 English</span>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
<!-- END HEADER -->

<!-- Mobile Sticky Contact Bar -->
<div class="visible-xs-block visible-sm-block" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 1000; padding: 10px; background: #fff; border-top: 1px solid #e6e6e6;">
  <div class="row no-padding">
    <div class="col-xs-6 no-padding p-r-5">
      <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-success btn-block">
        <i class="fa fa-phone"></i> {lang === 'th' ? 'โทร' : 'Call'}
      </a>
    </div>
    <div class="col-xs-6 no-padding p-l-5">
      <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-complete btn-block" style="display: flex; align-items: center; justify-content: center;">
        <img src="/assets/images/line-logo.png" alt="LINE" style="width: 20px; height: 20px;" />
      </a>
    </div>
  </div>
</div>