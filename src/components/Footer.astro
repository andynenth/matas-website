---
import type { Language } from '../i18n/translations';
import { t, getContactConfig, getLocalizedUrl } from '../i18n/utils.js';
import { translations } from '../i18n/translations.js';

export interface Props {
  lang?: Language;
}

const { lang = 'th' } = Astro.props;

const currentYear = new Date().getFullYear();
const siteName = t('site.name', lang);
const copyright = `© ${currentYear} ${siteName} ${t('footer.copyright', lang)}`;
const contact = getContactConfig(lang);

// Get quick links from translations
const quickLinks = translations[lang].footer.quickLinks.items.map(item => ({
  name: item.name,
  href: getLocalizedUrl(item.href, lang)
}));

// Get legal links from translations
const legalLinks = [
  { name: t('footer.legal.privacy', lang), href: getLocalizedUrl('/privacy', lang) },
  { name: t('footer.legal.terms', lang), href: getLocalizedUrl('/terms', lang) }
];
---

<!-- BEGIN FOOTER -->
<section class="p-b-55 p-t-75 xs-p-b-20 bg-master-darker">
  <div class="container">
    <div class="row">
      <div class="col-sm-4 col-xs-12 xs-m-b-40">
        <h3 class="text-white font-montserrat">{siteName}</h3>
        <p class="text-white fs-12 m-t-10">
          {t('footer.description', lang)}
        </p>
      </div>

      <div class="col-sm-2 col-xs-6 xs-m-b-20">
        <h6 class="font-montserrat text-uppercase fs-14 text-white p-b-10">
          {t('footer.quickLinks.title', lang)}
        </h6>
        <ul class="no-style">
          {quickLinks.map((link) => (
            <li class="m-b-5 no-padding">
              <a href={link.href} class="link text-white">{link.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="col-sm-3 col-xs-6 xs-m-b-20">
        <h6 class="font-montserrat text-uppercase fs-14 text-white p-b-10">
          {t('footer.contact.title', lang)}
        </h6>
        <ul class="no-style">
          <li class="m-b-5 no-padding">
            <span class="fs-12 font-montserrat bold all-caps p-r-10 text-white">{t('footer.contact.phone', lang)}</span>
            <a href={`tel:${contact.phone.number}`} onclick={contact.phone.trackingFunction} class="fs-14 text-white link">{contact.phone.display}</a>
          </li>
          <li class="m-b-5 no-padding">
            <span class="fs-12 font-montserrat bold all-caps p-r-10 text-white">{t('footer.contact.line', lang)}</span>
            <a href={contact.line.url} onclick={contact.line.trackingFunction} target="_blank" rel="noopener noreferrer" class="fs-14 text-white link">Matas.s</a>
          </li>
          <li class="m-b-5 no-padding">
            <span class="fs-12 font-montserrat bold all-caps p-r-10 text-white">{t('footer.contact.email', lang)}</span>
            <a href="mailto:info@mitsansuklaw.com" class="fs-14 text-white link">info@mitsansuklaw.com</a>
          </li>
        </ul>
      </div>

      <div class="col-sm-3 col-xs-12 xs-m-b-20">
        <h6 class="font-montserrat text-uppercase fs-14 text-white p-b-10">
          {t('footer.address.title', lang)}
        </h6>
        <address class="text-white fs-12">
          52/4 {t('footer.address.street', lang)}<br>
          {t('footer.address.subdistrict', lang)}<br>
          {t('footer.address.province', lang)}<br>
          {t('footer.address.country', lang)}
        </address>
        <p class="text-white fs-12 m-t-10">
          <span class="fs-12 font-montserrat bold all-caps p-r-10">{t('footer.address.hours', lang)}</span><br>
          {t('footer.address.hoursDetail', lang)}
        </p>
      </div>
    </div>

    <div class="row m-t-40">
      <div class="col-sm-6">
        <p class="fs-12 hint-text text-white">{copyright}</p>
      </div>
      <div class="col-sm-6 text-right xs-text-left">
        {legalLinks.map((link, index) => (
          <span>
            <a href={link.href} class="link text-white fs-12">{link.name}</a>
            {index < legalLinks.length - 1 && <span class="text-white p-l-5 p-r-5">|</span>}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
<!-- END FOOTER -->