---
export interface Props {
  lang?: 'th' | 'en';
  currentPath?: string;
}

const { lang = 'th', currentPath = '/' } = Astro.props;

// ===============================
// EXTRACTED CONSTANTS & CONFIG
// ===============================

// Site Configuration
const SITE_CONFIG = {
  th: {
    name: 'สำนักกฎหมายมิตรแสนสุข',
    tagline: 'บริการใกล้ตัว มาตรฐานระดับสากล'
  },
  en: {
    name: 'MS Law Office',
    tagline: 'Local Care, International Confidence'
  }
} as const;

// Navigation Configuration
const NAVIGATION_CONFIG = {
  th: [
    { name: 'หน้าแรก', href: '/' },
    { name: 'เกี่ยวกับเรา', href: '/about' },
    { name: 'บริการ', href: '/services' },
    { name: 'คำถามที่พบบ่อย', href: '/faq' },
    { name: 'ติดต่อเรา', href: '/contact' }
  ],
  en: [
    { name: 'Home', href: '/en/' },
    { name: 'About Us', href: '/en/about' },
    { name: 'Services', href: '/en/services' },
    { name: 'FAQ', href: '/en/faq' },
    { name: 'Contact', href: '/en/contact' }
  ]
} as const;

// Contact Configuration
const CONTACT_CONFIG = {
  phone: {
    number: '+66815144783',
    display: '081-514-4783',
    trackingFunction: 'trackPhoneClick()'
  },
  line: {
    url: 'https://line.me/ti/p/~Matas.s',
    trackingFunction: 'trackLineClick()',
    logo: '/assets/images/line-logo.png'
  }
} as const;

// Language Configuration
const LANGUAGE_CONFIG = {
  th: { flag: '🇹🇭', code: 'TH', name: 'ไทย' },
  en: { flag: '🇺🇸', code: 'EN', name: 'English' }
} as const;

// ===============================
// EXTRACTED HELPER FUNCTIONS
// ===============================

// Language Toggle Helper
const getLanguageToggleData = (currentLang: 'th' | 'en', path: string) => {
  const currentConfig = LANGUAGE_CONFIG[currentLang];
  const otherLang = currentLang === 'th' ? 'en' : 'th';
  const otherConfig = LANGUAGE_CONFIG[otherLang];

  const getToggleUrl = () => {
    if (currentLang === 'th') {
      return path === '/' ? '/en/' : `/en${path}`;
    } else {
      return path === '/en/' ? '/' : path.replace('/en', '');
    }
  };

  return {
    current: {
      ...currentConfig,
      isActive: true
    },
    other: {
      ...otherConfig,
      isActive: false,
      url: getToggleUrl()
    }
  };
};

// Navigation Helper
const isActive = (path: string) => {
  if (lang === 'en') {
    return currentPath === path || currentPath === path.replace('/en', '');
  }
  return currentPath === path;
};

// ===============================
// COMPUTED VALUES
// ===============================

const navigation = NAVIGATION_CONFIG[lang];
const siteName = SITE_CONFIG[lang].name;
const siteTagline = SITE_CONFIG[lang].tagline;
const languageToggle = getLanguageToggleData(lang, currentPath);
---

<style>
/* Updated hover styles - cache bust 2026-03-04-v4 */
nav.header.bg-master-darker a {
  transition: all 0.3s ease !important;
}

/* Menu navigation links */
nav.header.bg-master-darker .menu li a {
  color: #ffffff !important;
  transition: all 0.3s ease !important;
}

nav.header.bg-master-darker .menu li a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
}

/* Contact and language toggle links */
nav.header.bg-master-darker a:hover,
nav.header.bg-master-darker .language-toggle a:hover,
nav.header.bg-master-darker .header-inner a:hover,
nav.header.bg-master-darker div a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
  transform: none !important;
}

/* Mobile Responsive Styles (max-width: 767px) */
@media (max-width: 767px) {
  /* Mobile optimizations */
  .logo h3 {
    font-size: 16px !important;
  }

  /* Mobile navigation text sizing */
  nav.header.bg-master-darker .menu li a {
    font-size: 20px !important;
  }
}

/* Tablet Responsive Styles (768px - 991px) */
@media (min-width: 768px) and (max-width: 991px) {
  /* Ensure proper spacing on tablet */
  .header-inner {
    justify-content: space-between !important;
  }

  /* Optimize logo area for tablets */
  .logo h3 {
    font-size: 18px !important;
  }

  /* Prevent overflow on tablet */
  .pull-right .header-inner {
    flex-wrap: nowrap !important;
    overflow: hidden !important;
  }
}

/* Desktop Responsive Styles (min-width: 992px) */
@media (min-width: 992px) {
  /* Hide hamburger button on desktop - force hide with multiple selectors */
  nav.header.bg-master-darker .menu-toggler,
  .menu-toggler.visible-sm-inline,
  .menu-toggler.visible-xs-inline {
    display: none !important;
    visibility: hidden !important;
  }

  /* Desktop text optimizations */
  .visible-md-inline {
    white-space: nowrap !important;
  }
}

/* Mobile hamburger menu button styling */
nav.header.bg-master-darker .menu-toggler {
  border: 1px solid #ffffff !important;
  border-radius: 8px !important;
  background-color: transparent !important;
  padding: 8px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex-direction: column !important;
  margin-top: 2px !important;
}

nav.header.bg-master-darker .menu-toggler .one,
nav.header.bg-master-darker .menu-toggler .two,
nav.header.bg-master-darker .menu-toggler .three {
  background-color: #ffffff !important;
}


/* CSS Custom Properties */
:root {
  --header-height: 60px;
  --header-gap-large: 15px;
  --header-gap-medium: 10px;
  --header-gap-small: 5px;
  --icon-spacing: 5px;
  --logo-size: 18px;
  --separator-margin: 5px;
  --mobile-sticky-z: 1000;
  --mobile-padding: 10px;
}

/* Semantic CSS Classes for Header Layout */
.header-inner-flex {
  display: flex;
  align-items: center;
  height: var(--header-height);
}

.logo-title {
  margin: 0;
  line-height: 1.2;
}

.contact-container-large {
  display: inline-flex;
  align-items: center;
  gap: var(--header-gap-large);
}

.contact-container-medium {
  display: inline-flex;
  align-items: center;
  gap: var(--header-gap-medium);
}

.contact-link {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
}

.contact-link-padded {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
  padding: 2px 4px;
}

.icon-with-spacing {
  margin-right: var(--icon-spacing);
  vertical-align: middle;
}

.logo-sizing {
  width: var(--logo-size);
  height: var(--logo-size);
  vertical-align: middle;
}

.logo-sizing-mobile {
  width: 20px;
  height: 20px;
}

.separator-spacing {
  margin: 0 var(--separator-margin);
}

.separator-spacing-small {
  margin: 0 4px;
}

.mobile-sticky-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--mobile-sticky-z);
  padding: var(--mobile-padding);
}

.button-flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hidden-element {
  display: none;
}

</style>

<!-- BEGIN HEADER -->
<nav class="header bg-master-darker" data-pages="header">
  <div class="container relative">
    <!-- BEGIN LEFT CONTENT -->
    <div class="pull-left">
      <!-- .header-inner Allows to vertically Align elements to the Center-->
      <div class="header-inner header-inner-flex">
        <!-- BEGIN LOGO -->
        <div class="logo">
          <a href={lang === 'en' ? '/en/' : '/'}>
            <h3 class="text-white bold logo-title">{siteName}</h3>
          </a>
        </div>
      </div>
    </div>

    <!-- BEGIN HEADER TOGGLE FOR MOBILE & TABLET -->
    <div class="pull-right">
      <div class="header-inner header-inner-flex">
        <!-- Contact Info for Large Desktop (1200px+) -->
        <div class="visible-lg-inline hidden-xs hidden-sm p-r-20 contact-container-large">
          <a href={`tel:${CONTACT_CONFIG.phone.number}`} onclick={CONTACT_CONFIG.phone.trackingFunction} class="text-white fs-12 contact-link">
            <i class="fa fa-phone icon-with-spacing"></i> {CONTACT_CONFIG.phone.display}
          </a>

          <a href={CONTACT_CONFIG.line.url} onclick={CONTACT_CONFIG.line.trackingFunction} target="_blank" rel="noopener noreferrer" class="text-success fs-12 contact-link-padded">
            <img src={CONTACT_CONFIG.line.logo} alt="LINE" class="logo-sizing" />
          </a>

          <!-- Language Toggle -->
          <div class="language-toggle fs-12 contact-link">
            <div class="contact-link">
              <span class="text-white font-montserrat bold">{languageToggle.current.flag} {languageToggle.current.code}</span>
              <span class="text-white-50 separator-spacing">|</span>
              <a href={languageToggle.other.url} class="text-white">
                {languageToggle.other.flag} {languageToggle.other.code}
              </a>
            </div>
          </div>
        </div>

        <!-- Tablet-Optimized Contact (768-1199px) -->
        <div class="visible-md-inline hidden-lg hidden-xs hidden-sm p-r-15 contact-container-medium">
          <a href={`tel:${CONTACT_CONFIG.phone.number}`} onclick={CONTACT_CONFIG.phone.trackingFunction} class="text-white fs-11 contact-link">
            <i class="fa fa-phone icon-with-spacing"></i> {CONTACT_CONFIG.phone.display}
          </a>

          <!-- Tablet Language Toggle -->
          <div class="language-toggle fs-11 contact-link">
            <div class="contact-link">
              <span class="text-white font-montserrat bold">{languageToggle.current.flag}</span>
              <span class="text-white-50 separator-spacing-small">|</span>
              <a href={languageToggle.other.url} class="text-white">{languageToggle.other.flag}</a>
            </div>
          </div>
        </div>

        <div class="visible-sm-inline visible-xs-inline hidden-lg hidden-md menu-toggler pull-right p-l-10" data-pages="header-toggle" data-pages-element="#header">
          <div class="one"></div>
          <div class="two"></div>
          <div class="three"></div>
        </div>
      </div>
    </div>
    <!-- END HEADER TOGGLE FOR MOBILE & TABLET -->

    <!-- BEGIN RIGHT CONTENT -->
    <div class="menu-content mobile-dark pull-right clearfix" data-pages-direction="slideRight" id="header">
      <!-- BEGIN HEADER CLOSE TOGGLE FOR MOBILE -->
      <div class="pull-right">
        <a href="#" class="padding-10 visible-xs-inline visible-sm-inline pull-right m-t-10 m-b-10 m-r-10" data-pages="header-toggle" data-pages-element="#header">
          <i class="pg-close_line"></i>
        </a>
      </div>
      <!-- END HEADER CLOSE TOGGLE FOR MOBILE -->

      <!-- BEGIN MENU ITEMS -->
      <div class="header-inner">
        <ul class="menu">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.name}</a>
            </li>
          ))}

        </ul>

        <!-- Mobile Contact Info -->
        <div class="visible-xs-block visible-sm-block m-t-20">
          <div class="b-b b-grey-light p-b-10 m-b-10">
            <a href={`tel:${CONTACT_CONFIG.phone.number}`} onclick={CONTACT_CONFIG.phone.trackingFunction} class="btn btn-block btn-success m-b-5 hidden-element">
              <i class="fa fa-phone"></i> {lang === 'th' ? 'โทรศัพท์' : 'Call'} {CONTACT_CONFIG.phone.display}
            </a>
            <a href={CONTACT_CONFIG.line.url} onclick={CONTACT_CONFIG.line.trackingFunction} target="_blank" rel="noopener noreferrer" class="btn btn-block btn-complete m-b-10 hidden-element">
              <img src={CONTACT_CONFIG.line.logo} alt="LINE" style="width: 24px; height: 24px;" />
            </a>

            <!-- Mobile Language Toggle -->
            <div class="text-center p-t-10">
              <div class="language-toggle-mobile">
                <div>
                  <span class="text-white bold fs-14">{languageToggle.current.flag} {languageToggle.current.name}</span>
                  <span class="hint-text p-l-10 p-r-10">|</span>
                  <a href={languageToggle.other.url} class="text-white-50 fs-14">
                    {languageToggle.other.flag} {languageToggle.other.name}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
<!-- END HEADER -->

<!-- Mobile Sticky Contact Bar -->
<div class="visible-xs-block visible-sm-block mobile-sticky-bar">
  <div class="row no-padding">
    <div class="col-xs-6 no-padding p-r-5">
      <a href={`tel:${CONTACT_CONFIG.phone.number}`} onclick={CONTACT_CONFIG.phone.trackingFunction} class="btn btn-success btn-block">
        <i class="fa fa-phone"></i> {lang === 'th' ? 'โทร' : 'Call'}
      </a>
    </div>
    <div class="col-xs-6 no-padding p-l-5">
      <a href={CONTACT_CONFIG.line.url} onclick={CONTACT_CONFIG.line.trackingFunction} target="_blank" rel="noopener noreferrer" class="btn btn-complete btn-block button-flex-center">
        <img src={CONTACT_CONFIG.line.logo} alt="LINE" class="logo-sizing-mobile" />
      </a>
    </div>
  </div>
</div>