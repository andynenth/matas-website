---
import type { NavigationProps } from './types';

export interface Props extends NavigationProps {}

const { navigation, currentPath, isActive } = Astro.props;
---

<style>
/* Desktop navigation styling */
@media (min-width: 992px) {
  .menu li a { /* Targeting the ul.menu directly within this component's scope */
    color: #ffffff !important;
    transition: all 0.3s ease !important;
    font-size: 14px !important; /* Added font-size here */
  }
}

/* Existing hover styles, might need to be adjusted if the above rule takes over */
nav.header.bg-master-darker .menu li a:hover {
  color: rgba(255, 255, 255, 0.7) !important;
  text-decoration: none !important;
}
</style>

<ul class="menu">
  {navigation.map((item) => (
    <li>
      <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.name}</a>
    </li>
  ))}
</ul>