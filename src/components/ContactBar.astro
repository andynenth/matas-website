---
export interface Props {
  lang?: 'th' | 'en';
}

const { lang = 'th' } = Astro.props;

const phoneText = lang === 'th' ? 'โทร' : 'Call';
const lineText = 'LINE';
---

<!-- Desktop Contact Bar -->
<div class="hidden md:block bg-navy-700 text-white py-2">
  <div class="section-container">
    <div class="flex justify-center items-center space-x-8">
      <a
        href="tel:+66815144783"
        onclick="trackPhoneClick()"
        class="flex items-center space-x-2 hover:text-navy-200 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
        </svg>
        <span class="font-medium">{phoneText}: +66 81-514-4783</span>
      </a>

      <div class="text-navy-300">|</div>

      <a
        href="https://line.me/ti/p/~Matas.s"
        onclick="trackLineClick()"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center space-x-2 hover:text-navy-200 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"></path>
        </svg>
        <span class="font-medium">{lineText}: Matas.s</span>
      </a>
    </div>
  </div>
</div>

<!-- Mobile Sticky Contact Bar -->
<div class="fixed bottom-0 left-0 right-0 bg-navy-700 text-white p-3 z-50 md:hidden">
  <div class="flex space-x-3">
    <a
      href="tel:+66815144783"
      onclick="trackPhoneClick()"
      class="flex-1 bg-green-600 hover:bg-green-700 text-center py-3 rounded-lg font-medium transition-colors duration-200 flex items-center justify-center space-x-2"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
      </svg>
      <span>{phoneText}</span>
    </a>

    <a
      href="https://line.me/ti/p/~Matas.s"
      onclick="trackLineClick()"
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 bg-green-500 hover:bg-green-600 text-center py-3 rounded-lg font-medium transition-colors duration-200 flex items-center justify-center space-x-2"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"></path>
      </svg>
      <span>{lineText}</span>
    </a>
  </div>
</div>

<!-- Add padding to body to account for mobile sticky bar -->
<style>
  @media (max-width: 768px) {
    body {
      padding-bottom: 80px;
    }
  }
</style>