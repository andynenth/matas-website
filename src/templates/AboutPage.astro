---
// ===============================
// ABOUT PAGE TEMPLATE v1.0
// Single template supporting both languages
// ===============================

import type { Language } from '../i18n/index.js';
import { t } from '../i18n/utils.js';
import { translations } from '../i18n/index.js';

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactButtons from '../components/ContactButtons.astro';
import HeroSection from '../components/HeroSection.astro';

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;

// Get translated content
const aboutContent = translations[lang].pages.about;
const pageTitle = aboutContent.title;
const pageDescription = aboutContent.description;
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={lang === 'en' ? '/en/about' : '/about'} />

  <div class="m-t-60">
    <!-- Hero Section -->
    <HeroSection heroData={aboutContent.hero} />

    <!-- Attorney Profile Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="md-p-l-20 md-p-r-20 xs-no-padding">
        <h5 class="block-title hint-text no-margin">{aboutContent.attorney.title}</h5>
        <div class="row">
          <div class="col-md-6">
            <h1 class="m-t-5 m-b-30">{aboutContent.attorney.name}</h1>
            <p class="fs-16 m-b-30">{aboutContent.attorney.subtitle}</p>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">{aboutContent.attorney.education.title}</h6>
              <div class="bg-master-lightest padding-20">
                <ul class="no-style">
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    {aboutContent.attorney.education.middle}
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    {aboutContent.attorney.education.high}
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-university text-primary p-r-10"></i>
                    <strong>{aboutContent.attorney.education.university}</strong>
                  </li>
                </ul>
              </div>
            </div>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">{aboutContent.attorney.licenses.title}</h6>
              <div class="row">
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <img src="/assets/images/icons/license.png" alt="Certificate" style="width: 50px; height: 50px;" class="certificate-icon">
                    <p class="fs-12 m-t-10 no-margin"><strong>{aboutContent.attorney.licenses.lawyer}</strong></p>
                  </div>
                </div>
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <img src="/assets/images/icons/document-certification.png" alt="Certificate" style="width: 50px; height: 50px;" class="certificate-icon">
                    <p class="fs-12 m-t-10 no-margin"><strong>{aboutContent.attorney.licenses.notary}</strong></p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6 text-center">
            <div class="bg-white padding-40 m-t-20">
              <div style="width: 240px; height: 240px; margin: 0 auto 30px; overflow: hidden; border-radius: 50%;">
                <img
                  src="/assets/images/profile-image.png"
                  alt={aboutContent.attorney.name}
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <h4 class="text-black m-b-5">{t('pages.about.attorney.title', lang)} {aboutContent.attorney.name}</h4>
              <p class="hint-text fs-12">{aboutContent.attorney.education.university}</p>
              <p class="text-primary font-montserrat bold fs-14 m-t-15">
                {aboutContent.attorney.quote}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy & Approach Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <h5 class="block-title hint-text no-margin">{aboutContent.philosophy.title}</h5>
            <h1 class="m-t-5 m-b-30">{aboutContent.philosophy.subtitle}</h1>
            <p class="fs-16 m-b-30">
              {aboutContent.philosophy.description}
            </p>
          </div>

          <div class="col-md-6">
            <h5 class="block-title hint-text no-margin">{aboutContent.approach.title}</h5>
            <h2 class="m-t-5 m-b-30">{aboutContent.approach.subtitle}</h2>

            <div class="row">
              {aboutContent.approach.features.map((feature, index) => {
                const colors = ['bg-primary', 'bg-success', 'bg-complete'];
                return (
                  <div class="col-sm-4 text-center m-b-30">
                    <div class="bg-white padding-20">
                      <div class={`${colors[index]} hover-lift`} style="width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center;">
                        <span class="text-white font-montserrat bold" style="font-size: 24px;">{index + 1}</span>
                      </div>
                      <h5 class="text-black m-b-10">{feature.title}</h5>
                      <p class="hint-text fs-12">{feature.description}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience & Expertise Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center m-b-60">
        <h5 class="block-title hint-text no-margin">{aboutContent.expertise.subtitle}</h5>
        <h1 class="m-t-5 m-b-20">{aboutContent.expertise.title}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {aboutContent.expertise.description}
        </p>
      </div>

      <div class="row">
        {aboutContent.expertise.areas.map((area, index) => {
          const colors = ['text-primary', 'text-success', 'text-complete'];
          return (
            <div class="col-md-4 text-center m-b-40">
              <div class="bg-master-lightest padding-30">
                <i class={`fa ${area.icon} ${colors[index]}`} style="font-size: 48px;"></i>
                <h4 class="text-black m-t-20 m-b-15">{area.title}</h4>
                <p class="hint-text">{area.description}</p>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">{aboutContent.cta.title}</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          {aboutContent.cta.description}
        </p>

        <ContactButtons lang={lang} size="large" layout="horizontal" />
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</Layout>