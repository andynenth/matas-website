---
// ===============================
// SERVICES PAGE TEMPLATE v1.0
// Single template supporting both languages
// ===============================

import type { Language } from '../i18n/translations';
import { t } from '../i18n/utils.js';
import { translations } from '../i18n/translations.js';

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactButtons from '../components/ContactButtons.astro';

export interface Props {
  lang: Language;
}

const { lang } = Astro.props;

// Get translated content
const pageTitle = t('pages.services.title', lang);
const pageDescription = t('pages.services.description', lang);
const services = translations[lang].services;
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={lang === 'en' ? '/en/services' : '/services'} />

  <div class="m-t-60">
    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        <h5 class="block-title hint-text no-margin">{t('pages.home.services.title', lang)}</h5>
        <h1 class="light m-t-5 m-b-30">{t('pages.home.services.subtitle', lang)}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {t('pages.home.services.description', lang)}
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="row">
        {services.map((service, index) => (
          <div class="col-md-4 col-sm-6 m-b-40">
            <div class="bg-white padding-30 text-center hover-lift">
              <div class="m-b-20">
                <i class={`fa ${service.icon} text-primary`} style="font-size: 64px;"></i>
              </div>
              <h3 class="text-black m-b-20">{service.title}</h3>
              <p class="hint-text">{service.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Call-to-Action -->
      <div class="text-center m-t-60">
        <h2 class="m-b-30">{t('pages.home.cta.title', lang)}</h2>
        <p class="fs-16 m-b-40 col-md-8 col-md-offset-2 no-padding">
          {t('pages.home.cta.description', lang)}
        </p>
        <ContactButtons lang={lang} size="large" layout="horizontal" />
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</Layout>