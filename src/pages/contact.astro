---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'ติดต่อเรา';
const pageDescription = 'ติดต่อสำนักกฎหมายมิตรแสนสุข - ที่อยู่ เบอร์โทรศัพท์ อีเมล และแผนที่สำนักงาน';
---

<style>
  .block-title,
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Noto Sans Thai', sans-serif !important;
  }

  p, .fs-16, .hint-text {
    font-family: 'Noto Sans Thai', sans-serif !important;
  }
</style>

<Layout title={pageTitle} description={pageDescription} lang="th">
  <Header lang="th" currentPath="/contact" />

  <div class="m-t-60">
    <!-- Contact Section -->
    <section class="container container-fixed-lg p-t-65 p-b-100 sm-p-b-30 sm-m-b-30">
      <div class="row">
        <div class="col-md-6">
          <h2>ติดต่อสำนักงานกฎหมาย</h2>
          <div class="p-r-40 sm-p-r-0">
            <p>เรายินดีให้คำปรึกษาทางกฎหมายและช่วยเหลือแก้ไขปัญหาต่างๆ ด้วยความเป็นมิตรและมาตรฐานการบริการที่เป็นเลิศ</p>
            <br>

            <!-- Prominent Contact Buttons -->
            <div class="row m-b-30">
              <div class="col-sm-6 m-b-15">
                <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-success btn-block btn-lg">
                  <i class="fa fa-phone p-r-10"></i> โทรศัพท์
                  <br><span class="fs-16">081-514-4783</span>
                </a>
              </div>
              <div class="col-sm-6 m-b-15">
                <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-complete btn-block btn-lg">
                  <i class="fa fa-comments p-r-10"></i> LINE Chat
                  <br><span class="fs-16">Matas.s</span>
                </a>
              </div>
            </div>

            <br>
            <div class="panel bg-master-lightest" id="contact-panel">
              <div class="panel-body padding-30">
                <p class="semi-bold no-margin m-b-20">ช่องทางการติดต่ออื่นๆ</p>

                <div class="row">
                  <div class="col-sm-12 m-b-20">
                    <div class="flex-row">
                      <i class="fa fa-envelope text-primary p-r-15" style="font-size: 20px; width: 30px;"></i>
                      <div>
                        <p class="font-montserrat bold all-caps fs-12 text-black no-margin">อีเมล</p>
                        <a href="mailto:info@mitsansuklaw.com" class="fs-14 text-black">info@mitsansuklaw.com</a>
                      </div>
                    </div>
                  </div>

                  <div class="col-sm-12 m-b-20">
                    <div class="flex-row">
                      <i class="fa fa-clock-o text-primary p-r-15" style="font-size: 20px; width: 30px;"></i>
                      <div>
                        <p class="font-montserrat bold all-caps fs-12 text-black no-margin">เวลาทำการ</p>
                        <p class="fs-14 text-black no-margin">จันทร์ - ศุกร์: 9:00 - 18:00 น.</p>
                        <p class="fs-12 hint-text">กรณีเร่งด่วน สามารถติดต่อผ่าน LINE ได้ตลอดเวลา</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="visible-xs visible-sm b-b b-grey-light m-t-35 m-b-30"></div>
          <div class="p-l-40 sm-p-l-0 sm-p-t-10">
            <h3>ข้อมูลสำนักงาน<br>และบริการพิเศษ</h3>
            <p>ตั้งอยู่ในทำเลที่สะดวกต่อการเดินทาง พร้อมบริการที่หลากหลายสำหรับลูกค้าทั้งชาวไทยและชาวต่างชาติ</p>
            <br>

            <div class="row">
              <div class="col-sm-12 m-b-30">
                <h5 class="block-title hint-text m-b-10">ที่อยู่สำนักงาน</h5>
                <address class="m-t-10">
                  <strong>สำนักกฎหมายมิตรแสนสุข</strong><br>
                  52/4 ถนนมิตรสัมพันธ์<br>
                  ตำบลบ้านปึก อำเภอเมืองชลบุรี<br>
                  จังหวัดชลบุรี 20130<br>
                  ประเทศไทย
                </address>
                <br>
                <p class="hint-text no-margin">
                  <span class="fs-12 font-montserrat bold all-caps p-r-10">การเดินทาง</span><br>
                  <span class="fs-14">🚗 มีที่จอดรถหน้าสำนักงาน</span><br>
                  <span class="fs-14">🚌 รถเมล์สาย 3, 7, 15</span><br>
                  <span class="fs-14">📍 ใกล้ตลาดบ้านปึก และโรงพยาบาลชลบุรี</span>
                </p>
              </div>
            </div>

            <br>
            <h5 class="block-title hint-text m-b-10">บริการพิเศษ</h5>
            <br>
            <div class="row">
              <div class="col-sm-6 m-b-20">
                <div class="bg-white padding-15 text-center">
                  <i class="fa fa-clock-o text-success" style="font-size: 24px;"></i>
                  <p class="fs-12 m-t-10 no-margin"><strong>คำปรึกษาฟรี</strong></p>
                  <p class="fs-11 hint-text">เบื้องต้น 15-30 นาที</p>
                </div>
              </div>
              <div class="col-sm-6 m-b-20">
                <div class="bg-white padding-15 text-center">
                  <i class="fa fa-language text-complete" style="font-size: 24px;"></i>
                  <p class="fs-12 m-t-10 no-margin"><strong>แปลเร่งด่วน</strong></p>
                  <p class="fs-11 hint-text">เสร็จภายในวันเดียว</p>
                </div>
              </div>
              <div class="col-sm-6 m-b-20">
                <div class="bg-white padding-15 text-center">
                  <i class="fa fa-certificate text-primary" style="font-size: 24px;"></i>
                  <p class="fs-12 m-t-10 no-margin"><strong>รับรองเอกสาร</strong></p>
                  <p class="fs-11 hint-text">1-2 วันทำการ</p>
                </div>
              </div>
              <div class="col-sm-6 m-b-20">
                <div class="bg-white padding-15 text-center">
                  <i class="fa fa-globe text-warning" style="font-size: 24px;"></i>
                  <p class="fs-12 m-t-10 no-margin"><strong>บริการชาวต่างชาติ</strong></p>
                  <p class="fs-11 hint-text">ภาษาอังกฤษ</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Google Maps Section -->
    <section class="container-fluid no-padding no-overflow">
      <div class="container m-b-30">
        <div class="text-center">
          <h5 class="block-title hint-text no-margin">แผนที่สำนักงาน</h5>
          <h2 class="m-t-5 m-b-20">ตำแหน่งที่ตั้ง</h2>
          <p class="hint-text">52/4 ถนนมิตรสัมพันธ์ ตำบลบ้านปึก อำเภอเมืองชลบุรี 20130</p>
        </div>
      </div>

      <!-- Full Width Google Maps -->
      <div id="google-map" class="full-width no-overflow" style="height: 400px; position: relative;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3875.5431234567!2d100.98420!3d13.36111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTPCsDIxJzQwLjAiTiAxMDDCsDU5JzAzLjEiRQ!5e0!3m2!1sen!2sth!4v1234567890123!5m2!1sen!2sth"
          style="width: 100%; height: 100%; border: 0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="แผนที่สำนักงานกฎหมายมิตรแสนสุข">
        </iframe>

        <!-- Map Overlay -->
        <div style="position: absolute; bottom: 20px; left: 20px; background: rgba(255,255,255,0.95); padding: 15px; border-radius: 5px; max-width: 250px;">
          <h6 class="text-black m-b-5"><strong>สำนักกฎหมายมิตรแสนสุข</strong></h6>
          <p class="fs-12 hint-text m-b-10">52/4 ถนนมิตรสัมพันธ์ ตำบลบ้านปึก</p>
          <a href="https://maps.app.goo.gl/QwdyjZqbYySGo3JeA" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
            <i class="fa fa-external-link p-r-5"></i> เปิดใน Google Maps
          </a>
        </div>
      </div>

      <div class="container p-t-30 text-center">
        <a href="https://maps.app.goo.gl/QwdyjZqbYySGo3JeA" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          <i class="fa fa-map-marker p-r-10"></i> เปิดแผนที่ขนาดใหญ่
        </a>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">พร้อมให้บริการคุณแล้ววันนี้</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          ไม่ว่าจะเป็นปัญหากฎหมายใดๆ เรายินดีให้คำปรึกษาและหาทางออกที่ดีที่สุดสำหรับคุณ
        </p>

        <div class="row">
          <div class="col-sm-4 col-sm-offset-2 m-b-15">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-white btn-lg btn-block">
              <i class="fa fa-phone p-r-10"></i> โทร 081-514-4783
            </a>
          </div>
          <div class="col-sm-4 m-b-15">
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-success btn-lg btn-block">
              <i class="fa fa-comments p-r-10"></i> แชท LINE
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang="th" />
</Layout>