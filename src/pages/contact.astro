---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { detectLanguageFromPath, t, getContactConfig } from '../i18n/utils.js';
import { translations } from '../i18n/translations.js';

// Detect language from URL path
const lang = detectLanguageFromPath(Astro.url.pathname);
const currentPath = lang === 'en' ? '/en/contact' : '/contact';

// Get translated content
const contactContent = translations[lang].pages.contact;
const pageTitle = contactContent.title;
const pageDescription = contactContent.description;
const contact = getContactConfig(lang);
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={currentPath} />

  <div class="m-t-60">
    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        <h5 class="block-title hint-text no-margin">{contactContent.hero.subtitle}</h5>
        <h1 class="light m-t-5 m-b-30">{contactContent.hero.title}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {contactContent.hero.description}
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="container container-fixed-lg p-t-65 p-b-100 sm-p-b-30 sm-m-b-30">
      <div class="row">
        <div class="col-md-6">
          <h2>{contactContent.mainContact.title}</h2>
          <div class="p-r-40 sm-p-r-0">
            <p>{contactContent.mainContact.description}</p>
            <br>

            <!-- Prominent Contact Buttons -->
            <div class="contact-buttons-container">
              <div class="row">
                <div class="col-sm-6 col-md-4 col-sm-offset-2 col-md-offset-2 m-b-15">
                  <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-call btn-lg btn-block contact-button">
                    <i class="fa fa-phone p-r-10"></i> {contactContent.hero.mobileButtontext} 081-514-4783
                  </a>
                </div>
                <div class="col-sm-6 col-md-4 m-b-15">
                  <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-line btn-lg btn-block contact-button">
                    <img src="/assets/images/line-logo-48.png" alt="LINE" class="line-logo" style="width: 24px; height: 24px; margin-right: 10px; vertical-align: middle;">
                    {contactContent.hero.mobileButtontext} LINE
                  </a>
                </div>
              </div>
            </div>

            <br>
            <div class="panel bg-master-lightest" id="contact-panel">
              <div class="panel-body padding-30">
                <p class="semi-bold no-margin m-b-20">{contactContent.mainContact.otherChannelsTitle}</p>

                <div class="row">
                  <div class="col-sm-12 m-b-20">
                    <div class="flex-row">
                      <i class="fa fa-envelope text-primary p-r-15" style="font-size: 20px; width: 30px;"></i>
                      <div>
                        <p class="font-montserrat bold all-caps fs-12 text-black no-margin">{t('footer.contact.email', lang)}</p>
                        <a href={`mailto:${contact.email.address}`} class="fs-14 text-black">{contact.email.address}</a>
                      </div>
                    </div>
                  </div>

                  <div class="col-sm-12 m-b-20">
                    <div class="flex-row">
                      <i class="fa fa-clock-o text-primary p-r-15" style="font-size: 20px; width: 30px;"></i>
                      <div>
                        <p class="font-montserrat bold all-caps fs-12 text-black no-margin">{t('footer.address.hours', lang)}</p>
                        <p class="fs-14 text-black no-margin">{t('footer.address.hoursDetail', lang)}</p>
                        <p class="fs-12 hint-text">{lang === 'th' ? 'กรณีเร่งด่วน สามารถติดต่อผ่าน LINE ได้ตลอดเวลา' : 'For urgent cases, contact via LINE anytime'}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="visible-xs visible-sm b-b b-grey-light m-t-35 m-b-30"></div>
          <div class="p-l-40 sm-p-l-0 sm-p-t-10">
            <h3 set:html={contactContent.officeInfo.title}></h3>
            <p>{contactContent.officeInfo.description}</p>
            <br>

            <div class="row">
              <div class="col-sm-12 m-b-30">
                <h5 class="block-title hint-text m-b-10">{contactContent.officeInfo.addressTitle}</h5>
                <address class="m-t-10">
                  <strong>{contactContent.officeInfo.officeName}</strong><br>
                  52/4 Mit Samphan Road<br>
                  Ban Puek, Mueang Chonburi<br>
                  Chonburi 20130<br>
                  Thailand
                </address>
                <br>
                <p class="hint-text no-margin">
                  <span class="fs-12 font-montserrat bold all-caps p-r-10">{contactContent.officeInfo.transportation.title}</span><br>
                  <span class="fs-14">{contactContent.officeInfo.transportation.parking}</span><br>
                  <span class="fs-14">{contactContent.officeInfo.transportation.bus}</span><br>
                  <span class="fs-14">{contactContent.officeInfo.transportation.landmark}</span>
                </p>
              </div>
            </div>

            <br>
            <h5 class="block-title hint-text m-b-10">{contactContent.specialServices.title}</h5>
            <br>
            <div class="row">
              {contactContent.specialServices.services.map((service) => (
                <div class="col-sm-6 m-b-20">
                  <div class="bg-white padding-15 text-center">
                    <i class={`fa ${service.icon} ${service.iconColor}`} style="font-size: 24px;"></i>
                    <p class="fs-12 m-t-10 no-margin"><strong>{service.title}</strong></p>
                    <p class="fs-11 hint-text">{service.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Google Maps Section (Thai only) -->
    {lang === 'th' && (
    <section class="container-fluid no-padding no-overflow">
      <div class="container m-b-30">
        <div class="text-center">
          <h5 class="block-title hint-text no-margin">{contactContent.googleMaps.title}</h5>
          <h2 class="m-t-5 m-b-20">{contactContent.googleMaps.subtitle}</h2>
          <p class="hint-text">{contactContent.googleMaps.address}</p>
        </div>
      </div>

      <!-- Full Width Google Maps -->
      <div id="google-map" class="full-width no-overflow" style="height: 400px; position: relative;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3875.5431234567!2d100.98420!3d13.36111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTPCsDIxJzQwLjAiTiAxMDDCsDU5JzAzLjEiRQ!5e0!3m2!1sen!2sth!4v1234567890123!5m2!1sen!2sth"
          style="width: 100%; height: 100%; border: 0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="แผนที่สำนักงานกฎหมายมิตรแสนสุข">
        </iframe>

        <!-- Map Overlay -->
        <div style="position: absolute; bottom: 20px; left: 20px; background: rgba(255,255,255,0.95); padding: 15px; border-radius: 5px; max-width: 250px;">
          <h6 class="text-black m-b-5"><strong>{contactContent.googleMaps.overlayTitle}</strong></h6>
          <p class="fs-12 hint-text m-b-10">{contactContent.googleMaps.overlayAddress}</p>
          <a href="https://maps.app.goo.gl/QwdyjZqbYySGo3JeA" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
            <i class="fa fa-external-link p-r-5"></i> {contactContent.googleMaps.openInMaps}
          </a>
        </div>
      </div>

      <div class="container p-t-30 text-center">
        <a href="https://maps.app.goo.gl/QwdyjZqbYySGo3JeA" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          <i class="fa fa-map-marker p-r-10"></i> {contactContent.googleMaps.viewLargeMap}
        </a>
      </div>
    </section>
    )}

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">{contactContent.cta.title}</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          {contactContent.cta.description}
        </p>

        <div class="contact-buttons-container">
          <div class="row">
            <div class="col-sm-6 col-md-4 col-sm-offset-2 col-md-offset-2 m-b-15">
              <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-call btn-lg btn-block contact-button">
                <i class="fa fa-phone p-r-10"></i> {contactContent.hero.mobileButtontext}
              </a>
            </div>
            <div class="col-sm-6 col-md-4 m-b-15">
              <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-line btn-lg btn-block contact-button">
                <img src="/assets/images/line-logo-48.png" alt="LINE" class="line-logo" style="width: 24px; height: 24px; margin-right: 10px; vertical-align: middle;">
                {contactContent.hero.mobileButtontext}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</Layout>