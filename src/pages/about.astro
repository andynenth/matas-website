---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { detectLanguageFromPath, t } from '../i18n/utils.js';

// Detect language from URL path
const lang = detectLanguageFromPath(Astro.url.pathname);
const currentPath = lang === 'en' ? '/en/about' : '/about';

// Language-specific content
const pageTitle = lang === 'th' ? 'เกี่ยวกับเรา' : 'About Us';
const pageDescription = lang === 'th'
  ? 'ทำความรู้จักกับทนายความเมธัส ศรีศุกร์เจริญ และทีมงานของสำนักกฎหมายมิตรแสนสุข'
  : 'Learn about Attorney Matas Srisookcharoen and the MS Law Office team';
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={currentPath} />

  <div class="m-t-60">
    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        {lang === 'th' ? (
          <>
            <h5 class="block-title hint-text no-margin">เกี่ยวกับเรา</h5>
            <h1 class="light m-t-5 m-b-30">สำนักกฎหมายมิตรแสนสุข</h1>
            <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
              ก่อตั้งขึ้นเพื่อให้บริการทางด้านกฎหมายแก่ประชาชนทั่วไปและชาวต่างชาติที่อาศัยอยู่ในประเทศไทย
              ด้วยความเป็นมืออาชีพและมาตรฐานการบริการที่เป็นเลิศ
            </p>
          </>
        ) : (
          <>
            <h5 class="block-title hint-text no-margin">About Us</h5>
            <h1 class="light m-t-5 m-b-30">MS Law Office</h1>
            <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
              Established to provide legal services to the general public and foreign nationals residing in Thailand
              with professionalism and excellent service standards.
            </p>
          </>
        )}
      </div>
    </section>

    <!-- Attorney Profile Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="md-p-l-20 md-p-r-20 xs-no-padding">
        <h5 class="block-title hint-text no-margin">ทนายความหลัก</h5>
        <div class="row">
          <div class="col-md-6">
            <h1 class="m-t-5 m-b-30">เมธัส ศรีศุกร์เจริญ</h1>
            <p class="fs-16 m-b-30">ทนายความ และทนายความผู้รับรองเอกสารและลายมือชื่อ</p>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">ประวัติการศึกษา</h6>
              <div class="bg-master-lightest padding-20">
                <ul class="no-style">
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    มัธยมต้น: โรงเรียนจุฬาภรณ์ราชวิทยาลัย จังหวัดปทุมธานี
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    มัธยมปลาย: โรงเรียนเตรียมอุดมศึกษา
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-university text-primary p-r-10"></i>
                    <strong>ปริญญาตรี: นิติศาสตร์บัณฑิต มหาวิทยาลัยธรรมศาสตร์</strong>
                  </li>
                </ul>
              </div>
            </div>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">ใบอนุญาตประกอบวิชาชีพ</h6>
              <div class="row">
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <img src="/assets/images/icons/license.png" alt="Certificate" style="width: 50px; height: 50px;" class="certificate-icon">
                    <p class="fs-12 m-t-10 no-margin"><strong>ทนายความ</strong></p>
                  </div>
                </div>
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <i class="fa fa-stamp text-success" style="font-size: 32px;"></i>
                    <img src="/assets/images/icons/document-certification.png" alt="Certificate" style="width: 50px; height: 50px;" class="certificate-icon">
                    <p class="fs-12 m-t-10 no-margin"><strong>ทนายความผู้รับรองเอกสาร</strong></p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6 text-center">
            <div class="bg-white padding-40 m-t-20">
              <div style="width: 240px; height: 240px; background: #e6e6e6; border-radius: 50%; margin: 0 auto 30px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-user" style="font-size: 100px; color: #626262;"></i>
              </div>
              <h4 class="text-black m-b-5">ทนายความเมธัส ศรีศุกร์เจริญ</h4>
              <p class="hint-text fs-12">นิติศาสตร์บัณฑิต มหาวิทยาลัยธรรมศาสตร์</p>
              <p class="text-primary font-montserrat bold fs-14 m-t-15">
                "บริการด้วยความเป็นมิตร"
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy & Approach Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <h5 class="block-title hint-text no-margin">ปรัชญาการทำงาน</h5>
            <h1 class="m-t-5 m-b-30">"บริการด้วยความเป็นมิตร"</h1>
            <p class="fs-16 m-b-30">
              เราเชื่อว่าการให้บริการทางกฎหมายไม่ใช่เพียงแค่การทำงานตามหน้าที่
              แต่เป็นการสร้างความไว้วางใจและความมั่นใจให้กับลูกค้าในทุกขั้นตอน
              ด้วยความเป็นมิตรและความเข้าใจในปัญหาของลูกค้าเป็นสำคัญ
            </p>
          </div>

          <div class="col-md-6">
            <h5 class="block-title hint-text no-margin">แนวทางการทำงาน</h5>
            <h2 class="m-t-5 m-b-30">โปร่งใส เข้าถึงง่าย รวดเร็ว</h2>

            <div class="row">
              <div class="col-sm-4 text-center m-b-30">
                <div class="bg-white padding-20">
                  <div class="bg-primary" style="width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">1</span>
                  </div>
                  <h5 class="text-black m-b-10">โปร่งใส</h5>
                  <p class="hint-text fs-12">แจ้งข้อมูลและค่าใช้จ่ายอย่างชัดเจน ไม่มีค่าใช้จ่ายแอบแฝง</p>
                </div>
              </div>

              <div class="col-sm-4 text-center m-b-30">
                <div class="bg-white padding-20">
                  <div class="bg-success" style="width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">2</span>
                  </div>
                  <h5 class="text-black m-b-10">เข้าถึงง่าย</h5>
                  <p class="hint-text fs-12">ให้คำปรึกษาในภาษาที่เข้าใจง่าย พร้อมติดต่อได้ตลอดเวลา</p>
                </div>
              </div>

              <div class="col-sm-4 text-center m-b-30">
                <div class="bg-white padding-20">
                  <div class="bg-complete" style="width: 60px; height: 60px; border-radius: 50%; margin: 0 auto 15px; display: flex; align-items: center; justify-content: center;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">3</span>
                  </div>
                  <h5 class="text-black m-b-10">รวดเร็ว</h5>
                  <p class="hint-text fs-12">ดำเนินการอย่างมีประสิทธิภาพ ตรงต่อเวลา และไม่ทำให้เสียโอกาส</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience & Expertise Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center m-b-60">
        <h5 class="block-title hint-text no-margin">ความเชียวชาญ</h5>
        <h1 class="m-t-5 m-b-20">สาขากฎหมายที่ให้บริการ</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          ด้วยประสบการณ์และความเชี่ยวชาญในสาขากฎหมายต่างๆ เพื่อให้บริการที่ครอบคลุมและตรงตามความต้องการ
        </p>
      </div>

      <div class="row">
        <div class="col-md-4 text-center m-b-40">
          <div class="bg-master-lightest padding-30">
            <i class="fa fa-balance-scale text-primary" style="font-size: 48px;"></i>
            <h4 class="text-black m-t-20 m-b-15">กฎหมายแพ่งและพาณิชย์</h4>
            <p class="hint-text">สัญญา ข้อพิพาท และธุรกรรมทางการค้า</p>
          </div>
        </div>

        <div class="col-md-4 text-center m-b-40">
          <div class="bg-master-lightest padding-30">
            <i class="fa fa-users text-success" style="font-size: 48px;"></i>
            <h4 class="text-black m-t-20 m-b-15">กฎหมายครอบครัว</h4>
            <p class="hint-text">การสมรส การหย่า และมรดก</p>
          </div>
        </div>

        <div class="col-md-4 text-center m-b-40">
          <div class="bg-master-lightest padding-30">
            <i class="fa fa-certificate text-complete" style="font-size: 48px;"></i>
            <h4 class="text-black m-t-20 m-b-15">การรับรองเอกสาร</h4>
            <p class="hint-text">เอกสารสำหรับชาวต่างชาติและธุรกรรมระหว่างประเทศ</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">พร้อมให้คำปรึกษาแล้ววันนี้</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          ติดต่อเราเพื่อรับคำปรึกษาเบื้องต้นฟรี พร้อมแนวทางแก้ไขปัญหาที่เหมาะสมกับคุณ
        </p>

        <div class="row">
          <div class="col-sm-4 col-sm-offset-2 m-b-15">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-white btn-lg btn-block">
              <i class="fa fa-phone p-r-10"></i> โทร 081-514-4783
            </a>
          </div>
          <div class="col-sm-4 m-b-15">
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-success btn-lg btn-block">
              <i class="fa fa-comments p-r-10"></i> แชท LINE
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang="th" />
</Layout>