---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { detectLanguageFromPath } from '../i18n/utils.js';
import { translations } from '../i18n/translations.js';

// Detect language from URL path
const lang = detectLanguageFromPath(Astro.url.pathname);
const currentPath = lang === 'en' ? '/en/services' : '/services';

// Get translated content
const servicesContent = translations[lang].pages.services;
const pageTitle = servicesContent.title;
const pageDescription = servicesContent.description;
const detailedServices = servicesContent.detailedServices;

const processStepColors = ['bg-primary', 'bg-success', 'bg-complete', 'bg-warning'];
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={currentPath} />

  <div class="m-t-60">

    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        <h5 class="block-title hint-text no-margin">{servicesContent.hero.subtitle}</h5>
        <h1 class="light m-t-5 m-b-30">{servicesContent.hero.title}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {servicesContent.hero.description}
        </p>
      </div>
    </section>

    <!-- Services Detailed Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="row">
        {detailedServices.map((service, index) => (
          <div class="col-md-6 m-b-50">
            <div class="bg-white padding-40 hover-lift">
              <div class="row">
                <div class="col-xs-3">
                  <div class={`${service.bgColor} text-center padding-20`} style="border-radius: 10px;">
                    <i class={`fa ${service.icon} text-white`} style="font-size: 48px;"></i>
                  </div>
                </div>
                <div class="col-xs-9 p-l-20">
                  <h3 class="text-black m-b-15 m-t-0">{service.title}</h3>
                  <p class="hint-text fs-14 m-b-20">{service.description}</p>
                </div>
              </div>

              <div class="m-t-30">
                <h6 class="font-montserrat text-uppercase fs-12 text-black m-b-15">{servicesContent.serviceDetailsLabel}</h6>
                <ul class="no-style">
                  {service.details.map((detail) => (
                    <li class="m-b-10 no-padding">
                      <i class="fa fa-check text-success p-r-10"></i>
                      <span class="fs-14">{detail}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="m-t-30">
                <ContactButtons lang={lang} size="medium" layout="horizontal" />
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Process Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="text-center m-b-60">
          <h5 class="block-title hint-text no-margin">{servicesContent.process.subtitle}</h5>
          <h1 class="m-t-5 m-b-20">{servicesContent.process.title}</h1>
          <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
            {servicesContent.process.description}
          </p>
        </div>

        <div class="row">
          {servicesContent.process.steps.map((step, index) => (
            <div class="col-md-3 col-sm-6 text-center m-b-30">
              <div class="bg-white padding-30">
                <div class={`${processStepColors[index]}`} style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                  <span class="text-white font-montserrat bold" style="font-size: 32px;">{index + 1}</span>
                </div>
                <h4 class="text-black m-b-15">{step.title}</h4>
                <p class="hint-text fs-12">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing Information Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center m-b-60">
        <h5 class="block-title hint-text no-margin">{servicesContent.pricing.subtitle}</h5>
        <h1 class="m-t-5 m-b-20">{servicesContent.pricing.title}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {servicesContent.pricing.description}
        </p>
      </div>

      <div class="row">
        {servicesContent.pricing.plans.map((plan, index) => {
          const borderStyle = plan.featured ? 'border: 2px solid #007bff;' : '';
          const textColorClass = plan.featured ? 'text-primary' : (plan.urgent ? 'text-complete' : '');
          return (
            <div class="col-md-4 m-b-30">
              <div class={`${plan.bgColor} padding-30 text-center`} style={borderStyle}>
                <h4 class="text-black m-b-20">{plan.title}</h4>
                <div class="m-b-20">
                  <span class={`font-montserrat bold ${textColorClass}`} style={`font-size: ${plan.urgent ? '24px' : '32px'};`}>{plan.price}</span>
                  <p class="fs-12 hint-text">{plan.subtitle}</p>
                </div>
                <ul class="no-style text-left">
                  {plan.features.map((feature) => (
                    <li class="m-b-5 fs-12">
                      <i class="fa fa-check text-success p-r-10"></i>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          );
        })}
      </div>

      <div class="text-center m-t-40">
        <p class="hint-text m-b-30">
          {servicesContent.pricing.disclaimer}
        </p>
        <ContactButtons lang={lang} size="large" layout="horizontal" />
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">{servicesContent.cta.title}</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          {servicesContent.cta.description}
        </p>

        <ContactButtons lang={lang} size="large" layout="horizontal" />
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</Layout>