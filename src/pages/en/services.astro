---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Services';
const pageDescription = 'Comprehensive legal services from MS Law Office - dispute resolution, legal consultation, company registration, and more';

const services = [
  {
    title: 'Court Litigation Services',
    description: 'Professional legal consultation and litigation in all court levels with expertise and experience',
    details: [
      'Preliminary case analysis and assessment',
      'Preparation of documents and evidence',
      'Litigation in first instance, appeal, and supreme courts',
      'Negotiation and dispute mediation'
    ],
    icon: 'fa-balance-scale',
    bgColor: 'bg-primary'
  },
  {
    title: 'Legal Consultation',
    description: 'Legal advice in various fields with knowledge and real-world experience',
    details: [
      'Civil and Commercial Law',
      'Family Law and Inheritance',
      'Real Estate and Property Law',
      'Labor Law and Social Security'
    ],
    icon: 'fa-briefcase',
    bgColor: 'bg-success'
  },
  {
    title: 'Will Preparation',
    description: 'Draft and prepare legal wills according to law for family peace of mind',
    details: [
      'Consultation on asset allocation',
      'Draft wills according to wishes',
      'Verify legal compliance',
      'Secure storage of wills'
    ],
    icon: 'fa-file-text',
    bgColor: 'bg-complete'
  },
  {
    title: 'Estate Administration',
    description: 'Assistance in appointing estate administrators and legal procedures',
    details: [
      'Petition court for estate administrator appointment',
      'Prepare inventory of assets and debts',
      'Settle debts and distribute assets',
      'Report proceedings to the court'
    ],
    icon: 'fa-users',
    bgColor: 'bg-primary'
  },
  {
    title: 'Company Registration',
    description: 'Complete company registration services - fast, accurate, and legal',
    details: [
      'Register limited companies and limited partnerships',
      'Capital increase and objective changes',
      'Share transfer and director changes',
      'Company dissolution and liquidation'
    ],
    icon: 'fa-building',
    bgColor: 'bg-success'
  },
  {
    title: 'Document Translation (Express)',
    description: 'Legal and official document translation with accuracy certification',
    details: [
      'Government documents and education certificates',
      'Contracts and business documents',
      'Documents for visas and immigration',
      'Express translation service within one day'
    ],
    icon: 'fa-language',
    bgColor: 'bg-complete'
  },
  {
    title: 'Document Certification by Attorney',
    description: 'Document and signature certification by certified attorney',
    details: [
      'Certify document copies as true',
      'Certify signatures and handwriting',
      'Certify document translations',
      'Documents effective immediately, no waiting'
    ],
    icon: 'fa-certificate',
    bgColor: 'bg-primary'
  }
];
---

<Layout title={pageTitle} description={pageDescription} lang="en">
  <Header lang="en" currentPath="/en/services" />

  <div class="m-t-60">
    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        <h5 class="block-title hint-text no-margin">Our Services</h5>
        <h1 class="light m-t-5 m-b-30">Comprehensive Legal Services</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          We provide comprehensive legal services with over 10 years of expertise and experience,
          ready to provide transparent and professional consultation
        </p>
        <p class="hint-text col-md-6 col-md-offset-3 no-padding m-t-15">
          We prioritize friendliness and understanding of customer problems as important
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="row">
        {services.map((service, index) => (
          <div class="col-lg-4 col-md-6 m-b-40">
            <div class="bg-white hover-lift full-height" style="border: 1px solid #e6e6e6;">
              <!-- Service Header -->
              <div class={`text-center padding-30 ${service.bgColor}`}>
                <i class={`fa ${service.icon} text-white`} style="font-size: 48px;"></i>
                <h4 class="text-white m-t-15 m-b-5">{service.title}</h4>
              </div>

              <!-- Service Content -->
              <div class="padding-25">
                <h6 class="font-montserrat text-uppercase fs-12 text-black m-b-15">Service Details</h6>
                <p class="hint-text m-b-20">{service.description}</p>

                <ul class="no-style">
                  {service.details.map((detail) => (
                    <li class="m-b-10">
                      <i class="fa fa-check text-success p-r-10"></i>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="text-center m-b-60">
          <h5 class="block-title hint-text no-margin">Pricing</h5>
          <h1 class="m-t-5 m-b-30">Transparent and Competitive Rates</h1>
          <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
            Our pricing is transparent with no hidden fees. Consultation fees vary by case complexity.
          </p>
        </div>

        <div class="row">
          <!-- Initial Consultation -->
          <div class="col-lg-4 col-md-6 m-b-30">
            <div class="bg-white text-center padding-40 hover-lift">
              <div class="bg-success" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <span class="text-white font-montserrat bold" style="font-size: 32px;">1</span>
              </div>
              <h4 class="text-black m-b-15">Initial Consultation</h4>
              <span class="font-montserrat bold" style="font-size: 32px;">Free</span>
              <p class="hint-text m-t-15">Free initial consultation to understand your legal needs</p>
            </div>
          </div>

          <!-- Standard Services -->
          <div class="col-lg-4 col-md-6 m-b-30">
            <div class="bg-white text-center padding-40 hover-lift">
              <div class="bg-primary" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <span class="text-white font-montserrat bold" style="font-size: 32px;">2</span>
              </div>
              <h4 class="text-black m-b-15">Standard Services</h4>
              <span class="font-montserrat bold text-primary" style="font-size: 32px;">Agreed Rate</span>
              <p class="hint-text m-t-15">Competitive rates agreed upon before service delivery</p>
            </div>
          </div>

          <!-- Express Services -->
          <div class="col-lg-4 col-md-6 m-b-30">
            <div class="bg-white text-center padding-40 hover-lift">
              <div class="bg-complete" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <span class="text-white font-montserrat bold" style="font-size: 32px;">3</span>
              </div>
              <h4 class="text-black m-b-15">Express Services</h4>
              <span class="font-montserrat bold text-complete" style="font-size: 24px;">+50%</span>
              <p class="hint-text m-t-15">Urgent services available with express rates</p>
            </div>
          </div>
        </div>

        <div class="text-center m-t-40">
          <p class="fs-14 hint-text">
            All prices are inclusive of applicable taxes. Contact us for detailed quotations.
          </p>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">Need Legal Services?</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          Contact us today for free consultation and professional legal solutions tailored to your needs
        </p>

        <div class="row">
          <div class="col-sm-4 col-sm-offset-2 m-b-15">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-white btn-lg btn-block">
              <i class="fa fa-phone p-r-10"></i> Call 081-514-4783
            </a>
          </div>
          <div class="col-sm-4 m-b-15">
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-success btn-lg btn-block">
              <i class="fa fa-comments p-r-10"></i> LINE Chat
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang="en" />
</Layout>