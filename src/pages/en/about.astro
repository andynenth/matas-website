---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'About Us';
const pageDescription = 'Meet Attorney Matas Srisookcharoen and learn about MS Law Office team in Chonburi, Thailand';
---

<Layout title={pageTitle} description={pageDescription} lang="en">
  <Header lang="en" currentPath="/en/about" />

  <div class="m-t-60">
    <!-- Hero Section -->
    <section class="bg-master-lightest p-t-85 p-b-85">
      <div class="container text-center">
        <h5 class="block-title hint-text no-margin">About Us</h5>
        <h1 class="light m-t-5 m-b-30">MS Law Office</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          Established to provide comprehensive legal services to the general public and foreigners residing in Thailand
          with professionalism and excellent service standards
        </p>
      </div>
    </section>

    <!-- Attorney Profile Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="md-p-l-20 md-p-r-20 xs-no-padding">
        <h5 class="block-title hint-text no-margin">Principal Attorney</h5>
        <div class="row">
          <div class="col-md-6">
            <h1 class="m-t-5 m-b-30">Matas Srisookcharoen</h1>
            <p class="fs-16 m-b-30">Licensed Attorney and Document & Signature Certification Attorney</p>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">Education Background</h6>
              <div class="bg-master-lightest padding-20">
                <ul class="no-style">
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    Junior High School: Chulabhorn Royal College, Pathum Thani Province
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-graduation-cap text-primary p-r-10"></i>
                    Senior High School: Triam Udom Suksa School
                  </li>
                  <li class="m-b-10 no-padding">
                    <i class="fa fa-university text-primary p-r-10"></i>
                    <strong>Bachelor's Degree: Bachelor of Laws, Thammasat University</strong>
                  </li>
                </ul>
              </div>
            </div>

            <div class="m-b-40">
              <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">Professional Licenses</h6>
              <div class="row">
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <i class="fa fa-certificate text-success" style="font-size: 32px;"></i>
                    <p class="fs-12 m-t-10 no-margin"><strong>Licensed Attorney</strong></p>
                  </div>
                </div>
                <div class="col-sm-6 m-b-15">
                  <div class="bg-white padding-15 text-center">
                    <i class="fa fa-stamp text-success" style="font-size: 32px;"></i>
                    <p class="fs-12 m-t-10 no-margin"><strong>Document Certification Attorney</strong></p>
                  </div>
                </div>
              </div>
            </div>

            <p class="text-primary font-montserrat bold fs-14 m-t-15">
              "We are committed to providing legal services with transparency, professionalism,
              and understanding of our clients' needs to ensure the best possible outcomes."
            </p>
          </div>

          <!-- Experience Timeline -->
          <div class="col-md-6 m-t-60">
            <h6 class="font-montserrat text-uppercase fs-14 text-black p-b-15">Professional Experience</h6>

            <div class="timeline">
              <div class="timeline-item">
                <div class="timeline-marker">
                  <div class="bg-primary" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">1</span>
                  </div>
                </div>
                <div class="timeline-content">
                  <h4 class="text-black">10+ Years Experience</h4>
                  <p class="hint-text">Extensive experience in various areas of law with focus on client satisfaction</p>
                </div>
              </div>

              <div class="timeline-item m-t-40">
                <div class="timeline-marker">
                  <div class="bg-success" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">2</span>
                  </div>
                </div>
                <div class="timeline-content">
                  <h4 class="text-black">Specialized Services</h4>
                  <p class="hint-text">Court litigation, legal consultation, company registration, and document translation</p>
                </div>
              </div>

              <div class="timeline-item m-t-40">
                <div class="timeline-marker">
                  <div class="bg-complete" style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                    <span class="text-white font-montserrat bold" style="font-size: 24px;">3</span>
                  </div>
                </div>
                <div class="timeline-content">
                  <h4 class="text-black">Bilingual Services</h4>
                  <p class="hint-text">Fluent in Thai and English, serving both local and international clients</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-darker p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-white m-b-20">Ready to Get Professional Legal Assistance?</h1>
        <p class="fs-16 text-white m-b-40 col-md-8 col-md-offset-2 no-padding">
          Contact us today for free initial consultation and personalized legal solutions
        </p>

        <div class="row">
          <div class="col-sm-4 col-sm-offset-2 m-b-15">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-white btn-lg btn-block">
              <i class="fa fa-phone p-r-10"></i> Call 081-514-4783
            </a>
          </div>
          <div class="col-sm-4 m-b-15">
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-success btn-lg btn-block">
              <i class="fa fa-comments p-r-10"></i> LINE Chat
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang="en" />
</Layout>