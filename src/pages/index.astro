---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { detectLanguageFromPath } from '../i18n/utils.js';
import { translations } from '../i18n/translations.js';

// Detect language from URL
const lang = detectLanguageFromPath(Astro.url.pathname);
const currentPath = lang === 'en' ? '/en/' : '/';

// Get page data from translations
const pageData = translations[lang].pages.home;
const pageTitle = pageData.title;
const pageDescription = pageData.description;

// Get features from translations
const whyChooseFeatures = pageData.whyChoose.features;

// Get services from translations
const services = translations[lang].services;
---

<Layout title={pageTitle} description={pageDescription} lang={lang}>
  <Header lang={lang} currentPath={currentPath} />

  <div class="m-t-60">

    <!-- Hero Section -->
    <section class="p-t-85 p-b-85" style="position: relative; background-image: url('/assets/images/lawyer-hero-bg.png'); background-size: cover; background-position: center; background-attachment: fixed;">
      <!-- Blur overlay -->
      <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; backdrop-filter: blur(3px); background: rgba(255,255,255,0.8);"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <div class="text-center">
          <h5 class="block-title hint-text no-margin hero-subtitle" style="font-size: 18px; font-weight: bold;">{pageData.hero.subtitle}</h5>
          <h1 class="light">{pageData.hero.title}</h1>
          <p class="fs-16 m-t-30 m-b-30" set:html={pageData.hero.description}>
          </p>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center m-b-60">
        <h5 class="block-title hint-text no-margin">{pageData.services.title}</h5>
        <h1 class="m-t-5 m-b-30">{pageData.services.subtitle}</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          {pageData.services.description}
        </p>
        <p class="hint-text col-md-6 col-md-offset-3 no-padding m-t-15">
          {pageData.services.note}
        </p>
      </div>

      <!-- Services Grid -->
      <div class="container p-t-40">
        <div class="row">
          {services.map((service, index) => (
            <div class="col-md-4 col-sm-6 m-b-30">
              <div class="bg-white padding-20 text-center hover-lift">
                <div class="m-b-20">
                  {service.isImage ? (
                    <img
                      src={service.icon}
                      alt={service.title}
                      style="width: 48px; height: 48px;"
                      class="service-icon"
                    />
                  ) : (
                    <i class={`fa ${service.icon} text-primary`} style="font-size: 48px;"></i>
                  )}
                </div>
                <h4 class="text-black m-b-15">{service.title}</h4>
                <p class="hint-text">{service.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center m-t-40" style="display: none;">
          <a href={lang === 'en' ? '/en/services' : '/services'} class="btn btn-primary btn-lg">
            {translations[lang].buttons.viewAllServices}
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="text-center m-b-60">
          <h5 class="block-title hint-text no-margin">{pageData.whyChoose.title}</h5>
          <h1 class="m-t-5 m-b-30">{pageData.whyChoose.subtitle}</h1>
          <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
            {pageData.whyChoose.description}
          </p>
        </div>

        <div class="row">
          {whyChooseFeatures.map((feature, index) => (
            <div class="col-md-4 text-center m-b-40">
              <div class="bg-white padding-40 hover-lift">
                <div style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; background-color: transparent; border: 2px solid #000;">
                  {feature.isImage ? (
                    <img
                      src={feature.icon}
                      alt={feature.title}
                      style="width: 36px; height: 36px; filter: brightness(0);"
                    />
                  ) : (
                    <i class={`fa ${feature.icon}`} style="font-size: 36px; color: #000;"></i>
                  )}
                </div>
                <h4 class="text-black m-b-15">{feature.title}</h4>
                <p class="hint-text" set:html={feature.description}></p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center m-t-40">
          <a href={lang === 'en' ? '/en/about' : '/about'} class="btn btn-primary btn-lg">
            <i class="fa fa-user p-r-10"></i> {translations[lang].buttons.learnAboutLawyer}
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center">
        <h5 class="block-title hint-text no-margin">{pageData.testimonials.title}</h5>
        <h1 class="m-t-5 m-b-40">{pageData.testimonials.subtitle}</h1>

        <div class="bg-master-lightest padding-40">
          <p class="fs-16 hint-text">
            {pageData.testimonials.placeholder}
          </p>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-black m-b-20">{pageData.cta.title}</h1>
        <p class="fs-16 text-black m-b-40 col-md-8 col-md-offset-2 no-padding">
          {pageData.cta.description}
        </p>

        <ContactButtons lang={lang} size="large" layout="horizontal" />
      </div>
    </section>
  </div>

  <Footer lang={lang} />
</Layout>