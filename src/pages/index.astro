---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'หน้าแรก';
const pageDescription = 'สำนักกฎหมายมิตรแสนสุข - บริการด้านกฎหมายในจังหวัดชลบุรี ด้วยมาตรฐานการทำงานที่โปร่งใสและเป็นมืออาชีพ';

const services = [
  {
    title: 'การระงับข้อพิพาททางศาล',
    description: 'ให้คำปรึกษาและดำเนินคดีในศาลทุกชั้นด้วยความเชียวชาญและประสบการณ์',
    icon: 'fa-balance-scale'
  },
  {
    title: 'การให้คำปรึกษากฎหมาย',
    description: 'คำปรึกษาทางกฎหมายในหลากหลายสาขา ด้วยความรู้และประสบการณ์จริง',
    icon: 'fa-briefcase'
  },
  {
    title: 'การจัดทำพินัยกรรม',
    description: 'ร่างและจัดทำพินัยกรรมที่ถูกต้องตามกฎหมายเพื่อความมั่นใจของครอบครัว',
    icon: 'fa-file-text'
  },
  {
    title: 'การแต่งตั้งผู้จัดการมรดก',
    description: 'ช่วยเหลือในการแต่งตั้งผู้จัดการมรดกและดำเนินการตามกฎหมาย',
    icon: 'fa-users'
  },
  {
    title: 'การจดทะเบียนบริษัท',
    description: 'บริการจดทะเบียนบริษัทครบวงจร รวดเร็ว ถูกต้อง และเป็นไปตามกฎหมาย',
    icon: 'fa-building'
  },
  {
    title: 'การแปลเอกสาร (เร่งด่วน)',
    description: 'บริการแปลเอกสารทางกฎหมายและเอกสารราชการ พร้อมรับรองความถูกต้อง',
    icon: 'fa-language'
  },
  {
    title: 'การรับรองเอกสารโดยทนายความ',
    description: 'รับรองเอกสารและลายมือชื่อโดยทนายความผู้รับรองเอกสารและลายมือชื่อ',
    icon: 'fa-certificate'
  }
];
---

<Layout title={pageTitle} description={pageDescription} lang="th">
  <Header lang="th" currentPath="/" />

  <div class="m-t-60">

    <!-- Hero Section -->
    <section class="p-t-85 p-b-85" style="position: relative; background-image: url('/assets/images/lawyer-hero-bg.png'); background-size: cover; background-position: center; background-attachment: fixed;">
      <!-- Blur overlay -->
      <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; backdrop-filter: blur(3px); background: rgba(255,255,255,0.8);"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <div class="text-center">
          <h5 class="block-title hint-text no-margin hero-subtitle" style="font-size: 18px; font-weight: bold;">สำนักกฎหมาย</h5>
          <h1 class="light">สำนักกฎหมายมิตรแสนสุข</h1>
          <p class="fs-16 m-t-30 m-b-30">
            ยินดีต้อนรับสู่ สำนักกฎหมายมิตรแสนสุข (MS Law Office)<br>
            เรามุ่งมั่นให้บริการด้านกฎหมายแก่ประชาชนในจังหวัดชลบุรีและชาวต่างชาติที่อาศัยอยู่ในประเทศไทย<br>
            ด้วยมาตรฐานการทำงานที่โปร่งใสและเป็นมืออาชีพ เพื่อให้คุณมั่นใจได้ในทุกขั้นตอนของการดำเนินงานทางกฎหมาย
          </p>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center m-b-60">
        <h5 class="block-title hint-text no-margin">บริการของเรา</h5>
        <h1 class="m-t-5 m-b-30">บริการด้านกฎหมายครบวงจร</h1>
        <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
          ให้บริการด้านกฎหมายครบวงจร ด้วยความเชียวชาญและประสบการณ์มากกว่า 10 ปี
          พร้อมให้คำปรึกษาที่โปร่งใสและเป็นมืออาชีพ
        </p>
        <p class="hint-text col-md-6 col-md-offset-3 no-padding m-t-15">
          เราให้ความสำคัญกับความเป็นมิตรและความเข้าใจในปัญหาของลูกค้าเป็นสำคัญ
        </p>
      </div>

      <!-- Services Grid -->
      <div class="container p-t-40">
        <div class="row">
          {services.map((service, index) => (
            <div class="col-md-4 col-sm-6 m-b-30">
              <div class="bg-white padding-20 text-center hover-lift">
                <div class="m-b-20">
                  <i class={`fa ${service.icon} text-primary`} style="font-size: 48px;"></i>
                </div>
                <h4 class="text-black m-b-15">{service.title}</h4>
                <p class="hint-text">{service.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center m-t-40" style="display: none;">
          <a href="/services" class="btn btn-primary btn-lg">
            ดูบริการทั้งหมด
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container">
        <div class="text-center m-b-60">
          <h5 class="block-title hint-text no-margin">ทำไมต้องเลือกเรา</h5>
          <h1 class="m-t-5 m-b-30">ความเชี่ยวชาญที่คุณไว้วางใจได้</h1>
          <p class="fs-16 col-md-8 col-md-offset-2 no-padding">
            ด้วยประสบการณ์และความเชี่ยวชาญ เราพร้อมให้บริการที่โปร่งใส เข้าถึงได้ และเป็นมืออาชีพ
          </p>
        </div>

        <div class="row">
          <div class="col-md-4 text-center m-b-40">
            <div class="bg-white padding-40 hover-lift">
              <div class="bg-primary" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-university text-white" style="font-size: 36px;"></i>
              </div>
              <h4 class="text-black m-b-15">การศึกษาระดับสูง</h4>
              <p class="hint-text">นิติศาสตร์บัณฑิต<br>มหาวิทยาลัยธรรมศาสตร์</p>
            </div>
          </div>

          <div class="col-md-4 text-center m-b-40">
            <div class="bg-white padding-40 hover-lift">
              <div class="bg-success" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-certificate text-white" style="font-size: 36px;"></i>
              </div>
              <h4 class="text-black m-b-15">ใบอนุญาตครบถ้วน</h4>
              <p class="hint-text">ทนายความและทนายความ<br>ผู้รับรองเอกสาร</p>
            </div>
          </div>

          <div class="col-md-4 text-center m-b-40">
            <div class="bg-white padding-40 hover-lift">
              <div class="bg-complete" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-users text-white" style="font-size: 36px;"></i>
              </div>
              <h4 class="text-black m-b-15">บริการเป็นมิตร</h4>
              <p class="hint-text">เข้าใจปัญหา ให้คำปรึกษา<br>ด้วยความเป็นมิตร</p>
            </div>
          </div>
        </div>

        <div class="text-center m-t-40">
          <a href="/about" class="btn btn-primary btn-lg">
            <i class="fa fa-user p-r-10"></i> เรียนรู้เกี่ยวกับทนายความ
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="container container-fixed-lg p-t-75 p-b-85">
      <div class="text-center">
        <h5 class="block-title hint-text no-margin">ความเห็นจากลูกค้า</h5>
        <h1 class="m-t-5 m-b-40">ประสบการณ์และความพึงพอใจจากผู้ใช้บริการ</h1>

        <div class="bg-master-lightest padding-40">
          <p class="fs-16 hint-text">
            ส่วนนี้พร้อมสำหรับเพิ่มความเห็นและประสบการณ์จากลูกค้าในอนาคต
          </p>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="bg-master-lightest p-t-75 p-b-85">
      <div class="container text-center">
        <h1 class="light text-black m-b-20">ต้องการคำปรึกษาทางกฎหมาย?</h1>
        <p class="fs-16 text-black m-b-40 col-md-8 col-md-offset-2 no-padding">
          ติดต่อเราวันนี้เพื่อรับคำปรึกษาเบื้องต้นฟรี และแผนการดำเนินงานที่เหมาะสมกับคุณ
        </p>

        <div class="row">
          <div class="col-sm-4 col-sm-offset-2 m-b-15">
            <a href="tel:+66815144783" onclick="trackPhoneClick()" class="btn btn-primary btn-lg btn-block">
              <i class="fa fa-phone p-r-10"></i> โทร 081-514-4783
            </a>
          </div>
          <div class="col-sm-4 m-b-15">
            <a href="https://line.me/ti/p/~Matas.s" onclick="trackLineClick()" target="_blank" rel="noopener noreferrer" class="btn btn-success btn-lg btn-block">
              <i class="fa fa-comments p-r-10"></i> แชท LINE
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer lang="th" />
</Layout>